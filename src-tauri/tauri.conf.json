{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PathSmith",
  "mainBinaryName": "PathSmith",
  "version": "0.1.0",
  "identifier": "com.pathsmith.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "PathSmith",
        "width": 1280,
        "height": 800,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "freezePrototype": true,
      "csp": {
        "default-src": "'self' asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1420 asset: data: blob:",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "img-src": "'self' asset: http://asset.localhost http://localhost:1420 data: blob:",
        "style-src": "'self' 'unsafe-inline' http://localhost:1420",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Sort media libraries and clean empty folders from one desktop workspace.",
    "longDescription": "PathSmith is a local-first desktop app for organizing personal files, sorting media libraries, and safely cleaning empty folders after duplicate cleanup or manual pruning.",
    "macOS": {
      "bundleName": "PathSmith",
      "minimumSystemVersion": "11.0"
    }
  }
}
