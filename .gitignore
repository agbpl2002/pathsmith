# I ignore dependency folders and generated frontend output.
node_modules/
dist/
.vite/

# I ignore package manager debug logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# I ignore Rust and Tauri build artifacts.
src-tauri/target/
src-tauri/gen/

# I ignore macOS Finder and filesystem metadata.
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100/
.Trashes/

# I ignore Windows Explorer metadata and recycle-bin leftovers.
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# I ignore common Linux desktop and filesystem leftovers.
*~
.fuse_hidden*
.Trash-*/
.directory
.nfs*
